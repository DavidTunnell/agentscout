<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>AgentScout — {{ n_opportunities }} new agent opportunities</title>
</head>
<body style="margin:0;padding:0;background:#f3f4f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#111827;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#f3f4f6;padding:24px 0;">
  <tr><td align="center">
    <table role="presentation" width="640" cellspacing="0" cellpadding="0" style="max-width:640px;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">

      <tr><td style="padding:20px 28px;border-bottom:1px solid #e5e7eb;">
        <div style="font-size:13px;color:#6b7280;letter-spacing:0.04em;text-transform:uppercase;">AgentScout · {{ cycle_date }}</div>
        <h1 style="margin:6px 0 0;font-size:22px;font-weight:600;color:#111827;">{{ n_opportunities }} new agent {% if n_opportunities == 1 %}opportunity{% else %}opportunities{% endif %}</h1>
        <div style="margin-top:10px;font-size:13px;color:#4b5563;">
          {{ active_hours }} active hours observed · {{ n_clusters }} clusters analyzed
          {% if total_time_saved_hours > 0.0 %}· est. ~{{ total_time_saved_hours | round(method="ceil", precision=1) }}h/week saved if all top items implemented{% endif %}
          · cost ${{ cost_usd_str }}
        </div>
      </td></tr>

      {% if top_recs | length == 0 %}
      <tr><td style="padding:32px 28px;text-align:center;color:#6b7280;font-size:14px;">
        No recommendations crossed the confidence threshold this cycle. AgentScout will keep watching.
      </td></tr>
      {% else %}

      {% for r in top_recs %}
      <tr><td style="padding:24px 28px;border-bottom:1px solid #f3f4f6;">
        <div style="display:inline-block;padding:2px 10px;background:#10b981;color:#ffffff;font-size:11px;font-weight:600;border-radius:999px;letter-spacing:0.03em;text-transform:uppercase;">{{ r.tier_label }}</div>
        <h2 style="margin:8px 0 4px;font-size:18px;font-weight:600;color:#111827;">{{ r.name }}</h2>
        <p style="margin:6px 0 0;font-size:14px;line-height:1.55;color:#374151;">{{ r.description }}</p>

        <div style="margin-top:12px;font-size:13px;color:#6b7280;">
          <strong style="color:#374151;">Observed:</strong> {{ r.observed_pattern }}
        </div>

        <div style="margin-top:10px;font-size:13px;color:#374151;">
          {% if r.is_quantitative and r.frequency_per_week and r.est_time_saved_minutes %}
            <strong>Frequency:</strong> {{ r.frequency_per_week | round(method="ceil", precision=1) }}/week ·
            <strong>Saves:</strong> ~{{ (r.frequency_per_week * r.est_time_saved_minutes) | round(method="ceil") }} min/week
          {% elif r.strategic_value %}
            <strong>Strategic value:</strong> {{ r.strategic_value }}
          {% endif %}
          · <strong>Build:</strong> {{ r.build_complexity }} · <strong>Confidence:</strong> {{ r.confidence_pct }}%
        </div>

        {% if r.starter_scaffold %}
        <details style="margin-top:12px;">
          <summary style="cursor:pointer;font-size:12px;color:#4b5563;">Starter Agent SDK scaffold</summary>
          <pre style="margin:8px 0 0;padding:12px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:4px;font-size:12px;color:#111827;white-space:pre-wrap;line-height:1.5;">{{ r.starter_scaffold }}</pre>
        </details>
        {% endif %}

        <table role="presentation" cellspacing="0" cellpadding="0" style="margin-top:14px;">
          <tr>
            <td><a href="{{ r.implemented_url | safe }}" style="display:inline-block;padding:8px 14px;background:#10b981;color:#ffffff;font-size:13px;font-weight:500;text-decoration:none;border-radius:6px;">Implemented</a></td>
            <td style="padding-left:6px;"><a href="{{ r.not_interested_url | safe }}" style="display:inline-block;padding:8px 14px;background:#ffffff;color:#374151;font-size:13px;font-weight:500;text-decoration:none;border:1px solid #d1d5db;border-radius:6px;">Not Interested</a></td>
            <td style="padding-left:6px;"><a href="{{ r.maybe_later_url | safe }}" style="display:inline-block;padding:8px 14px;background:#ffffff;color:#374151;font-size:13px;font-weight:500;text-decoration:none;border:1px solid #d1d5db;border-radius:6px;">Maybe Later</a></td>
          </tr>
        </table>
      </td></tr>
      {% endfor %}

      {% if additional_recs | length > 0 %}
      <tr><td style="padding:20px 28px;background:#f9fafb;">
        <h3 style="margin:0 0 12px;font-size:13px;color:#6b7280;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;">Additional Recommendations</h3>
        <ul style="margin:0;padding:0;list-style:none;">
          {% for r in additional_recs %}
          <li style="padding:8px 0;border-bottom:1px solid #f3f4f6;font-size:13px;color:#374151;">
            <strong>{{ r.name }}</strong>
            <span style="color:#6b7280;">[{{ r.tier_label }} · {{ r.confidence_pct }}% conf]</span>
            <div style="margin-top:4px;">
              <a href="{{ r.implemented_url | safe }}" style="font-size:12px;color:#10b981;text-decoration:none;margin-right:10px;">Implemented</a>
              <a href="{{ r.not_interested_url | safe }}" style="font-size:12px;color:#6b7280;text-decoration:none;margin-right:10px;">Not Interested</a>
              <a href="{{ r.maybe_later_url | safe }}" style="font-size:12px;color:#6b7280;text-decoration:none;">Maybe Later</a>
            </div>
          </li>
          {% endfor %}
        </ul>
      </td></tr>
      {% endif %}

      {% endif %}

      <tr><td style="padding:18px 28px;background:#f3f4f6;font-size:11px;color:#9ca3af;line-height:1.6;">
        Cycle {{ cycle_id }} · Sent by AgentScout running locally on your machine.<br/>
        Pause any time from the AgentScout tray menu. To stop receiving these emails, quit the app.
      </td></tr>

    </table>
  </td></tr>
</table>
</body>
</html>
